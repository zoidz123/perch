# Copy to `.env` and fill in. These are the only two knobs.

# Public domain whose A/AAAA record points at this VM. The phone reaches the
# relay as wss://$RELAY_DOMAIN, and this is what you bake into the perch server's
# PERCH_RELAY_URL (e.g. wss://relay.example.com).
RELAY_DOMAIN=relay.example.com

# Email Let's Encrypt uses for expiry / problem notices.
LETSENCRYPT_EMAIL=you@example.com
